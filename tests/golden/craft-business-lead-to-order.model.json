{
  "version": "0.4",
  "type": "document",
  "body": [
    {
      "type": "process",
      "name": "CraftBusinessLeadToOrder",
      "annotations": [],
      "body": [
        {
          "type": "when",
          "annotations": [],
          "trigger": "lead.created"
        },
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "lead.source"
            },
            "operator": "=",
            "right": {
              "type": "string",
              "value": "referral"
            }
          },
          "then": [
            {
              "type": "assign",
              "annotations": [],
              "target": "lead.priority",
              "value": {
                "type": "string",
                "value": "high"
              }
            },
            {
              "type": "assign",
              "annotations": [],
              "target": "lead.sales_path",
              "value": {
                "type": "string",
                "value": "premium"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "sales",
              "message": "Handle referral lead first"
            }
          ],
          "elseIf": [
            {
              "annotations": [],
              "condition": {
                "type": "comparison",
                "left": {
                  "type": "field",
                  "path": "lead.source"
                },
                "operator": "=",
                "right": {
                  "type": "string",
                  "value": "aroundhome"
                }
              },
              "then": [
                {
                  "type": "assign",
                  "annotations": [],
                  "target": "lead.priority",
                  "value": {
                    "type": "string",
                    "value": "low"
                  }
                },
                {
                  "type": "assign",
                  "annotations": [],
                  "target": "lead.sales_path",
                  "value": {
                    "type": "string",
                    "value": "standard"
                  }
                }
              ]
            }
          ],
          "else": null
        },
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "logical",
            "operator": "and",
            "conditions": [
              {
                "type": "comparison",
                "left": {
                  "type": "field",
                  "path": "lead.project_type"
                },
                "operator": "!=",
                "right": {
                  "type": "string",
                  "value": "kitchen"
                }
              },
              {
                "type": "comparison",
                "left": {
                  "type": "field",
                  "path": "lead.project_type"
                },
                "operator": "!=",
                "right": {
                  "type": "string",
                  "value": "interior"
                }
              }
            ]
          },
          "then": [
            {
              "type": "transition",
              "annotations": [],
              "target": "lead.status",
              "value": {
                "type": "string",
                "value": "disqualified"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "sales",
              "message": "Outside target project type"
            },
            {
              "type": "stop",
              "annotations": []
            }
          ],
          "elseIf": [],
          "else": null
        },
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "lead.estimated_value"
            },
            "operator": "<",
            "right": {
              "type": "number",
              "value": 10000
            }
          },
          "then": [
            {
              "type": "transition",
              "annotations": [],
              "target": "lead.status",
              "value": {
                "type": "string",
                "value": "disqualified"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "sales",
              "message": "Below minimum project value"
            },
            {
              "type": "stop",
              "annotations": []
            }
          ],
          "elseIf": [],
          "else": null
        },
        {
          "type": "transition",
          "annotations": [],
          "target": "lead.status",
          "value": {
            "type": "string",
            "value": "qualified"
          }
        },
        {
          "type": "assign",
          "annotations": [],
          "target": "lead.owner",
          "value": {
            "type": "string",
            "value": "sales"
          }
        }
      ]
    },
    {
      "type": "process",
      "name": "QuoteToOrder",
      "annotations": [],
      "body": [
        {
          "type": "when",
          "annotations": [],
          "trigger": "quote.accepted"
        },
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "order.deposit_received"
            },
            "operator": "=",
            "right": {
              "type": "boolean",
              "value": false
            }
          },
          "then": [
            {
              "type": "transition",
              "annotations": [],
              "target": "order.status",
              "value": {
                "type": "string",
                "value": "awaiting_deposit"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "finance",
              "message": "Deposit required before confirmation"
            },
            {
              "type": "stop",
              "annotations": []
            }
          ],
          "elseIf": [],
          "else": null
        },
        {
          "type": "transition",
          "annotations": [],
          "target": "order.status",
          "value": {
            "type": "string",
            "value": "confirmed"
          }
        },
        {
          "type": "create",
          "annotations": [],
          "entity": "production_order"
        },
        {
          "type": "notify",
          "annotations": [],
          "target": "operations",
          "message": "Order ready for production planning"
        }
      ]
    },
    {
      "type": "stateflow",
      "name": "OrderLifecycle",
      "annotations": [],
      "states": [
        "qualified",
        "quoted",
        "awaiting_deposit",
        "confirmed",
        "in_production",
        "scheduled_for_installation",
        "completed",
        "cancelled"
      ],
      "transitions": [
        {
          "from": "qualified",
          "to": "quoted"
        },
        {
          "from": "quoted",
          "to": "awaiting_deposit"
        },
        {
          "from": "quoted",
          "to": "confirmed"
        },
        {
          "from": "awaiting_deposit",
          "to": "confirmed"
        },
        {
          "from": "confirmed",
          "to": "in_production"
        },
        {
          "from": "in_production",
          "to": "scheduled_for_installation"
        },
        {
          "from": "scheduled_for_installation",
          "to": "completed"
        },
        {
          "from": "qualified",
          "to": "cancelled"
        },
        {
          "from": "quoted",
          "to": "cancelled"
        },
        {
          "from": "awaiting_deposit",
          "to": "cancelled"
        }
      ]
    },
    {
      "type": "rule",
      "name": "NoProductionWithoutDeposit",
      "annotations": [],
      "appliesTo": "order",
      "body": [
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "order.deposit_received"
            },
            "operator": "=",
            "right": {
              "type": "boolean",
              "value": false
            }
          },
          "then": [
            {
              "type": "require",
              "annotations": [],
              "requirement": "finance_clearance"
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "operations",
              "message": "Production blocked until deposit is received"
            }
          ],
          "elseIf": [],
          "else": null
        }
      ]
    }
  ]
}
