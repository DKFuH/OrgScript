{
  "version": "0.4",
  "type": "document",
  "body": [
    {
      "type": "process",
      "name": "LeadQualification",
      "annotations": [
        {
          "key": "owner",
          "value": "sales_ops"
        },
        {
          "key": "status",
          "value": "active"
        }
      ],
      "body": [
        {
          "type": "when",
          "annotations": [],
          "trigger": "lead.created"
        },
        {
          "type": "if",
          "annotations": [
            {
              "key": "note",
              "value": "Track referral lead handling separately."
            }
          ],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "lead.source"
            },
            "operator": "=",
            "right": {
              "type": "string",
              "value": "referral"
            }
          },
          "then": [
            {
              "type": "assign",
              "annotations": [],
              "target": "lead.priority",
              "value": {
                "type": "string",
                "value": "high"
              }
            },
            {
              "type": "assign",
              "annotations": [],
              "target": "lead.path",
              "value": {
                "type": "string",
                "value": "premium"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "sales",
              "message": "New referral lead"
            }
          ],
          "elseIf": [
            {
              "annotations": [],
              "condition": {
                "type": "comparison",
                "left": {
                  "type": "field",
                  "path": "lead.source"
                },
                "operator": "=",
                "right": {
                  "type": "string",
                  "value": "ads"
                }
              },
              "then": [
                {
                  "type": "assign",
                  "annotations": [],
                  "target": "lead.priority",
                  "value": {
                    "type": "string",
                    "value": "normal"
                  }
                },
                {
                  "type": "assign",
                  "annotations": [],
                  "target": "lead.path",
                  "value": {
                    "type": "string",
                    "value": "standard"
                  }
                }
              ]
            }
          ],
          "else": null
        },
        {
          "type": "if",
          "annotations": [
            {
              "key": "review",
              "value": "Revisit the budget threshold each quarter."
            }
          ],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "lead.budget"
            },
            "operator": "<",
            "right": {
              "type": "number",
              "value": 10000
            }
          },
          "then": [
            {
              "type": "transition",
              "annotations": [],
              "target": "lead.status",
              "value": {
                "type": "string",
                "value": "disqualified"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "sales",
              "message": "Budget below threshold"
            },
            {
              "type": "stop",
              "annotations": []
            }
          ],
          "elseIf": [],
          "else": null
        },
        {
          "type": "transition",
          "annotations": [],
          "target": "lead.status",
          "value": {
            "type": "string",
            "value": "qualified"
          }
        }
      ]
    }
  ],
  "metadata": {
    "headerVersion": 1,
    "languages": {
      "source": "en",
      "comments": "en",
      "annotations": "en",
      "context": "en"
    }
  }
}
