{
  "version": "0.4",
  "type": "document",
  "body": [
    {
      "type": "stateflow",
      "name": "IncidentLifecycle",
      "annotations": [],
      "states": [
        "open",
        "triaged",
        "investigating",
        "mitigated",
        "resolved",
        "closed"
      ],
      "transitions": [
        {
          "from": "open",
          "to": "triaged"
        },
        {
          "from": "triaged",
          "to": "investigating"
        },
        {
          "from": "triaged",
          "to": "mitigated"
        },
        {
          "from": "investigating",
          "to": "mitigated"
        },
        {
          "from": "mitigated",
          "to": "resolved"
        },
        {
          "from": "resolved",
          "to": "closed"
        }
      ]
    },
    {
      "type": "role",
      "name": "OnCallEngineer",
      "annotations": [],
      "can": [
        "triage incident",
        "assign responder",
        "update status",
        "resolve incident"
      ],
      "cannot": []
    },
    {
      "type": "role",
      "name": "IncidentManager",
      "annotations": [],
      "can": [
        "escalate incident",
        "declare major incident",
        "notify stakeholders"
      ],
      "cannot": []
    },
    {
      "type": "policy",
      "name": "EscalationPolicy",
      "annotations": [],
      "clauses": [
        {
          "annotations": [],
          "condition": {
            "type": "logical",
            "operator": "and",
            "conditions": [
              {
                "type": "comparison",
                "left": {
                  "type": "field",
                  "path": "incident.severity"
                },
                "operator": "=",
                "right": {
                  "type": "string",
                  "value": "high"
                }
              },
              {
                "type": "comparison",
                "left": {
                  "type": "field",
                  "path": "incident.status"
                },
                "operator": "=",
                "right": {
                  "type": "string",
                  "value": "open"
                }
              }
            ]
          },
          "then": [
            {
              "type": "require",
              "annotations": [],
              "requirement": "triage_sla"
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "on_call_manager",
              "message": "SLA Warning: High severity incident untriaged"
            }
          ]
        },
        {
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "incident.status"
            },
            "operator": "=",
            "right": {
              "type": "string",
              "value": "investigating"
            }
          },
          "then": [
            {
              "type": "require",
              "annotations": [],
              "requirement": "regular_status_updates"
            }
          ]
        }
      ]
    },
    {
      "type": "process",
      "name": "IncidentHandling",
      "annotations": [],
      "body": [
        {
          "type": "when",
          "annotations": [],
          "trigger": "system.alert_received"
        },
        {
          "type": "create",
          "annotations": [],
          "entity": "incident"
        },
        {
          "type": "assign",
          "annotations": [],
          "target": "incident.severity",
          "value": {
            "type": "string",
            "value": "medium"
          }
        },
        {
          "type": "transition",
          "annotations": [],
          "target": "incident.status",
          "value": {
            "type": "string",
            "value": "open"
          }
        },
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "alert.source"
            },
            "operator": "=",
            "right": {
              "type": "string",
              "value": "critical_infrastructure"
            }
          },
          "then": [
            {
              "type": "assign",
              "annotations": [],
              "target": "incident.severity",
              "value": {
                "type": "string",
                "value": "high"
              }
            },
            {
              "type": "notify",
              "annotations": [],
              "target": "on_call_team",
              "message": "Critical alert detected"
            }
          ],
          "elseIf": [],
          "else": null
        },
        {
          "type": "if",
          "annotations": [],
          "condition": {
            "type": "comparison",
            "left": {
              "type": "field",
              "path": "incident.status"
            },
            "operator": "=",
            "right": {
              "type": "string",
              "value": "triaged"
            }
          },
          "then": [
            {
              "type": "assign",
              "annotations": [],
              "target": "incident.primary_responder",
              "value": {
                "type": "string",
                "value": "on_call_engineer"
              }
            },
            {
              "type": "transition",
              "annotations": [],
              "target": "incident.status",
              "value": {
                "type": "string",
                "value": "investigating"
              }
            }
          ],
          "elseIf": [],
          "else": {
            "annotations": [],
            "body": [
              {
                "type": "notify",
                "annotations": [],
                "target": "incident_manager",
                "message": "Incident requiring triage"
              }
            ]
          }
        }
      ]
    }
  ]
}
