{
  "comments": {
    "lineComment": "#"
  },
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ]
  ],
  "wordPattern": "(@?[A-Za-z_][A-Za-z0-9_.-]*)|(-?\\d+(?:\\.\\d+)?)"
}
